{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(npm init *)",
      "Bash(npx create-* *)",
      "Bash(mkdir -p *)",
      "Bash(npx playwright test *)",
      "Bash(npx cypress run *)",
      "Bash(npx jest *)",
      "Bash(npx vitest *)",
      "Bash(npx newman run *)",
      "Bash(npx backstop *)",
      "Bash(npx artillery *)",
      "Bash(hurl --test *)",
      "Bash(k6 run *)",
      "Bash(locust *)",
      "Bash(maestro test *)",
      "Bash(flutter test *)",
      "Bash(python -m pytest *)",
      "Bash(go test *)",
      "Bash(npx axe *)",
      "Bash(npx pa11y *)",
      "Bash(npx pa11y-ci *)",
      "Bash(npx lighthouse *)",
      "Bash(npx license-checker *)",
      "Bash(pip-licenses *)",
      "Bash(npx hadolint *)",
      "Bash(npx source-map-explorer *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard)"
    ]
  },
  "env": {},
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.js"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/drift-detector.js",
            "statusMessage": "Checking for environment drift..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-files.js"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gatekeeper-check.js",
            "statusMessage": "Checking for secrets and regressions..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-bash.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/context-monitor.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/audit-logger.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/test-results-parser.js",
            "statusMessage": "Parsing test results..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-format.js"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/track-file-changes.js"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/tool-failure-tracker.js",
            "statusMessage": "Logging tool failure..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact-save.js",
            "statusMessage": "Saving critical state before compaction..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-compact-recovery.js",
            "statusMessage": "Recovering workflow state..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notify-approval.js"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/subagent-tracker.js",
            "statusMessage": "Tracking agent completion..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/execution-report.js",
            "statusMessage": "Collecting execution metrics..."
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prompt-stats.js",
            "statusMessage": "Generating session stats..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|authentication_failed|billing_error|invalid_request|server_error|max_output_tokens",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-failure-handler.js",
            "statusMessage": "Preserving state after failure..."
          }
        ]
      }
    ]
  }
}
